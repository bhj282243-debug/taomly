# ══════════════════════════════════════════════════════════════════
# Taomly — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, local, or any Postgres)
DATABASE_URL=postgresql://user:password@host:5432/taomly

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-minimum-32-characters-long

# Fernet encryption key for Telegram bot tokens — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# Super Admin credentials
# SUPERADMIN_PASSWORD is REQUIRED — app will not start without it.
# Generate with: openssl rand -hex 32
SUPERADMIN_PASSWORD=your-strong-superadmin-password-here
# SUPERADMIN_EMAIL defaults to superadmin@taomly.uz if not set
SUPERADMIN_EMAIL=superadmin@taomly.uz

# ── TELEGRAM ──────────────────────────────────────────────────────

# Platform bot token (from @BotFather)
BOT_TOKEN=1234567890:AAF...

# Base URL where this app is deployed (used for webhook URLs)
WEBHOOK_URL=https://taomly.onrender.com

# Webhook secret token (auto-derived from SECRET_KEY if not set)
# Telegram requires: [A-Za-z0-9_-], length 1-256
# WEBHOOK_SECRET=optional-override

# ── AI (OPTIONAL) ─────────────────────────────────────────────────

# Enable AI features (default: false — all endpoints return feature_not_available)
AI_ENABLED=false

# AI Provider: openrouter | openai | anthropic | gemini
AI_PROVIDER=openrouter

# API key for the selected provider
# AI_API_KEY=your-api-key-here

# Model to use (examples below per provider)
# OpenRouter:  mistralai/mistral-7b-instruct
# OpenAI:      gpt-4o-mini
# Anthropic:   claude-sonnet-4-6
# Gemini:      gemini-1.5-flash
AI_MODEL=mistralai/mistral-7b-instruct

# ── OPTIONAL ──────────────────────────────────────────────────────

# Sentry DSN for error monitoring
# SENTRY_DSN=https://xxx@sentry.io/xxx

# CORS: comma-separated allowed origins (empty = allow all — dev only)
# ALLOWED_ORIGINS=https://taomly.uz,https://taomly.onrender.com

# JWT token TTL in hours (default: 24)
# ACCESS_TOKEN_EXPIRE_HOURS=24

# Telegram initData max age in seconds (default: 3600 = 1h, recommended by Telegram)
# MAX_INIT_DATA_AGE_SECONDS=3600

# Rate limiting overrides
# RATE_LIMIT_LOGIN=10/minute
# RATE_LIMIT_API=120/minute
# RATE_LIMIT_SUPERADMIN_LOGIN=5/minute

# Trusted proxy hosts for X-Forwarded-For (ProxyHeadersMiddleware)
# "*"         — trust any proxy (safe on Render/Railway where app is not exposed directly)
# "127.0.0.1" — trust only local proxy (nginx on same machine)
# Do NOT use "*" if your app is directly accessible from the internet without a proxy.
# TRUSTED_PROXY_HOSTS=*

# ── TEST DATABASE (used by pytest) ────────────────────────────────
# Separate DB for tests — never use production DB for tests
# If not set, tests use SQLite in-memory
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/taomly_test
